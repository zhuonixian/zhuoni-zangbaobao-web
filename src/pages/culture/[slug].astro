---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { cultures, getCultureBySlug } from '@/data/cultures';

export function getStaticPaths() {
  return cultures.map((culture) => ({
    params: { slug: culture.slug },
    props: { culture },
  }));
}

const { culture } = Astro.props;

// 找到上一个和下一个文化板块用于导航
const currentIndex = cultures.findIndex((c) => c.slug === culture.slug);
const prevCulture = currentIndex > 0 ? cultures[currentIndex - 1] : null;
const nextCulture = currentIndex < cultures.length - 1 ? cultures[currentIndex + 1] : null;
---

<BaseLayout title={`${culture.title} - 藏宝宝`} ogImage={culture.image}>
  <!-- Hero Banner with parallax-style image -->
  <section class="relative pt-0">
    <!-- Full-width image header -->
    <div class="relative h-[40vh] md:h-[50vh] overflow-hidden">
      <img
        src={culture.image}
        alt={culture.title}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-ink-blue/90 via-ink-blue/40 to-transparent"></div>
      <!-- Breadcrumb -->
      <nav class="absolute top-24 left-0 right-0 text-sm text-white/70 z-10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <a href="/" class="hover:text-white transition">首页</a>
          <span class="mx-2">/</span>
          <a href="/culture" class="hover:text-white transition">文化故事</a>
          <span class="mx-2">/</span>
          <span class="text-white font-medium">{culture.title}</span>
        </div>
      </nav>
      <!-- Title overlay -->
      <div class="absolute bottom-0 left-0 right-0 z-10 pb-10">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <span
            class="inline-block px-4 py-1 rounded-full text-xs font-medium tracking-wider text-white/90 mb-4"
            style={`background-color: ${culture.color};`}
          >
            {culture.subtitle}
          </span>
          <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight">
            {culture.title}
          </h1>
          <p class="mt-4 text-white/70 text-lg max-w-2xl mx-auto leading-relaxed">
            {culture.description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <section class="bg-cream py-16 md:py-20">
    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      {culture.detail.map((paragraph, i) => (
        <div class="mb-8 last:mb-0">
          <p class="text-earth-brown text-lg leading-[1.9] indent-8">
            {paragraph}
          </p>
        </div>
      ))}
    </article>
  </section>

  <!-- Decorative divider -->
  <div class="bg-cream pb-8">
    <div class="max-w-3xl mx-auto px-4 flex items-center gap-4">
      <div class="flex-1 h-px bg-linen"></div>
      <span class="text-bronze-gold text-sm tracking-[0.3em]">秘境卓尼</span>
      <div class="flex-1 h-px bg-linen"></div>
    </div>
  </div>

  <!-- Prev/Next Navigation -->
  <section class="bg-white py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {prevCulture ? (
          <a
            href={`/culture/${prevCulture.slug}`}
            class="group flex items-center gap-4 p-5 rounded-lg border border-linen hover:border-bronze-gold/40 hover:shadow-sm transition-all"
          >
            <span class="text-2xl text-earth-brown/40 group-hover:text-bronze-gold transition">&#8592;</span>
            <div>
              <span class="text-xs text-earth-brown/50">上一篇</span>
              <p class="text-ink-blue font-medium group-hover:text-tibetan-red transition">{prevCulture.title}</p>
            </div>
          </a>
        ) : (
          <div />
        )}
        {nextCulture ? (
          <a
            href={`/culture/${nextCulture.slug}`}
            class="group flex items-center justify-end gap-4 p-5 rounded-lg border border-linen hover:border-bronze-gold/40 hover:shadow-sm transition-all text-right"
          >
            <div>
              <span class="text-xs text-earth-brown/50">下一篇</span>
              <p class="text-ink-blue font-medium group-hover:text-tibetan-red transition">{nextCulture.title}</p>
            </div>
            <span class="text-2xl text-earth-brown/40 group-hover:text-bronze-gold transition">&#8594;</span>
          </a>
        ) : (
          <div />
        )}
      </div>
    </div>
  </section>

  <!-- Back to Culture List -->
  <section class="bg-white pb-16">
    <div class="text-center">
      <a
        href="/culture"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-ink-blue border-2 border-ink-blue/10 hover:border-tibetan-red hover:text-tibetan-red transition font-medium"
      >
        <span>&#8592;</span> 返回文化故事
      </a>
    </div>
  </section>
</BaseLayout>
