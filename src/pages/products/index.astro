---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import { products, categories } from '@/data/products';

// 选取部分代表性产品用于轮播展示
const featured = products.slice(0, 8);
---

<BaseLayout title="高原珍品 - 卓尼藏宝宝">
  <!-- Product Carousel Hero -->
  <section
    class="relative bg-gradient-to-br from-prairie-green/90 to-prairie-green overflow-hidden"
    x-data={`{
      items: ${JSON.stringify(featured.map(p => ({ name: p.name, image: p.image, category: p.category })))},
      current: 0,
      total: ${featured.length},
      track: null,
      startX: 0,
      scrollLeft: 0,
      isDragging: false,
      autoTimer: null,
      init() {
        this.track = this.$refs.track;
        this.startAuto();
        this.track.addEventListener('mouseenter', () => this.stopAuto());
        this.track.addEventListener('mouseleave', () => this.startAuto());
        this.track.addEventListener('touchstart', (e) => { this.stopAuto(); this.onPointerDown(e.touches[0].clientX); }, { passive: true });
        this.track.addEventListener('touchmove', (e) => this.onPointerMove(e.touches[0].clientX), { passive: true });
        this.track.addEventListener('touchend', () => { this.onPointerUp(); this.startAuto(); });
        this.track.addEventListener('mousedown', (e) => { this.stopAuto(); this.onPointerDown(e.clientX); });
        window.addEventListener('mousemove', (e) => { if(this.isDragging) this.onPointerMove(e.clientX); });
        window.addEventListener('mouseup', () => { if(this.isDragging) { this.onPointerUp(); this.startAuto(); } });
      },
      onPointerDown(x) {
        this.isDragging = true;
        this.startX = x;
        this.scrollLeft = this.track.scrollLeft;
        this.track.style.cursor = 'grabbing';
        this.track.style.scrollSnapType = 'none';
        this.track.style.scrollBehavior = 'auto';
      },
      onPointerMove(x) {
        if (!this.isDragging) return;
        const dx = this.startX - x;
        this.track.scrollLeft = this.scrollLeft + dx;
      },
      onPointerUp() {
        this.isDragging = false;
        this.track.style.cursor = 'grab';
        this.track.style.scrollSnapType = 'x mandatory';
        this.track.style.scrollBehavior = 'smooth';
        this.syncCurrent();
      },
      syncCurrent() {
        const w = this.track.children[0]?.offsetWidth || 1;
        this.current = Math.round(this.track.scrollLeft / w) % this.total;
      },
      next() {
        this.current = (this.current + 1) % this.total;
        this.scrollTo(this.current);
      },
      prev() {
        this.current = (this.current - 1 + this.total) % this.total;
        this.scrollTo(this.current);
      },
      goTo(i) {
        this.current = i;
        this.scrollTo(i);
      },
      scrollTo(i) {
        const child = this.track.children[i];
        if (child) child.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      },
      startAuto() {
        this.stopAuto();
        this.autoTimer = setInterval(() => this.next(), 3500);
      },
      stopAuto() {
        if (this.autoTimer) { clearInterval(this.autoTimer); this.autoTimer = null; }
      }
    }`}
  >
    <!-- Title overlay -->
    <div class="relative z-10 text-center pt-28 pb-4 px-4">
      <span class="inline-block text-bronze-gold text-sm tracking-[0.3em] mb-3">OUR PRODUCTS</span>
      <h1 class="text-4xl md:text-5xl font-light text-white">高原珍品</h1>
      <p class="mt-3 text-white/60 text-lg">来自海拔2000米以上雪域高原的天然馈赠</p>
    </div>

    <!-- Carousel area -->
    <div class="relative z-10 pb-6 pt-2">
      <!-- Gradient masks on edges -->
      <div class="pointer-events-none absolute left-0 top-0 bottom-6 w-16 bg-gradient-to-r from-prairie-green/90 to-transparent z-20"></div>
      <div class="pointer-events-none absolute right-0 top-0 bottom-6 w-16 bg-gradient-to-l from-prairie-green/90 to-transparent z-20"></div>

      <!-- Nav arrows -->
      <button
        @click="prev()"
        class="hidden md:flex absolute left-4 top-1/2 -translate-y-1/2 z-30 w-10 h-10 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm text-white hover:bg-white/40 transition"
        aria-label="上一张"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <button
        @click="next()"
        class="hidden md:flex absolute right-4 top-1/2 -translate-y-1/2 z-30 w-10 h-10 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm text-white hover:bg-white/40 transition"
        aria-label="下一张"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </button>

      <!-- Scroll track -->
      <div
        x-ref="track"
        class="flex gap-4 overflow-x-auto px-8 md:px-16 snap-x snap-mandatory cursor-grab scrollbar-hide"
        style="-ms-overflow-style: none; scrollbar-width: none;"
      >
        {featured.map((product, i) => (
          <div class="flex-shrink-0 w-[260px] md:w-[280px] snap-center">
            <div class="relative rounded-xl overflow-hidden shadow-lg group">
              <div class="aspect-[3/4] bg-white/10">
                <img
                  src={product.image}
                  alt={product.name}
                  loading={i < 3 ? 'eager' : 'lazy'}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <span class="inline-block px-2 py-0.5 rounded text-xs text-white/80 bg-white/20 backdrop-blur-sm mb-1">{product.category}</span>
                <p class="text-white font-medium text-sm">{product.name}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Dot indicators -->
      <div class="flex justify-center gap-1.5 mt-4">
        {featured.map((_, i) => (
          <button
            @click={`goTo(${i})`}
            class="w-2 h-2 rounded-full transition-all duration-300"
            x-bind:class={`current === ${i} ? 'bg-white w-6' : 'bg-white/40 hover:bg-white/60'`}
            aria-label={`第${i + 1}张`}
          />
        ))}
      </div>
    </div>

    <!-- Bottom decorative line -->
    <div class="h-1 bg-gradient-to-r from-tibetan-red via-bronze-gold to-tibetan-red"></div>
  </section>

  <!-- Hide scrollbar -->
  <style is:global>
    .scrollbar-hide::-webkit-scrollbar { display: none; }
  </style>

  <!-- Category Filter -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div
      x-data="{ active: 'all' }"
      class="flex flex-wrap gap-3 justify-center"
    >
      {categories.map((cat) => (
        <button
          type="button"
          class="px-5 py-2 rounded-full text-sm font-medium transition"
          x-bind:class={cat.slug === 'all'
            ? `active === '${cat.slug}' ? 'bg-tibetan-red text-white' : 'bg-white text-ink-blue'`
            : `active === '${cat.slug}' ? 'bg-tibetan-red text-white' : 'bg-white text-ink-blue'`
          }
          x-on:click={`active = '${cat.slug}'`}
          x-bind:aria-pressed={`active === '${cat.slug}'`}
        >
          {cat.name}
        </button>
      ))}
    </div>
  </section>

  <!-- Product Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map((product) => (
        <div
          x-data={`{ show: true }`}
          x-init={`show = active === 'all' || active === '${product.categorySlug}'`}
          x-effect={`show = active === 'all' || active === '${product.categorySlug}'`}
          x-show="show"
          x-transition
        >
          <ProductCard product={product} />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
