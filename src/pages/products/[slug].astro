---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import { products, getProductBySlug } from '@/data/products';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

const categoryColors: Record<string, string> = {
  mushroom: 'bg-amber-100 text-amber-800',
  herbs: 'bg-green-100 text-green-800',
  livestock: 'bg-red-100 text-red-800',
  'wild-plants': 'bg-emerald-100 text-emerald-800',
  'grain-oil': 'bg-yellow-100 text-yellow-800',
  honey: 'bg-orange-100 text-orange-800',
  crafts: 'bg-purple-100 text-purple-800',
};

const tagColor = categoryColors[product.categorySlug] || 'bg-gray-100 text-gray-800';

const relatedProducts = products
  .filter((p) => p.categorySlug === product.categorySlug && p.slug !== product.slug)
  .slice(0, 3);
---

<BaseLayout title={`${product.name} - 卓尼藏宝宝`} ogImage={product.image}>
  <!-- Breadcrumb -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-4">
    <nav class="text-sm text-earth-brown">
      <a href="/" class="hover:text-tibetan-red transition">首页</a>
      <span class="mx-2">/</span>
      <a href="/products" class="hover:text-tibetan-red transition">产品展示</a>
      <span class="mx-2">/</span>
      <span class="text-ink-blue font-medium">{product.name}</span>
    </nav>
  </section>

  <!-- Product Detail -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Left: Image -->
      <div class="aspect-square rounded-lg overflow-hidden bg-gradient-to-br from-prairie-green/80 to-prairie-green">
        <img
          src={product.image}
          alt={product.name}
          loading="lazy"
          onerror="this.style.display='none'"
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Right: Info -->
      <div class="flex flex-col justify-center">
        <!-- Category Tag -->
        <span class={`inline-block self-start px-3 py-1 rounded text-sm font-medium ${tagColor}`}>
          {product.category}
        </span>

        <!-- Product Name -->
        <h1 class="mt-4 text-3xl md:text-4xl font-bold text-ink-blue">
          {product.name}
        </h1>

        <!-- Detail Text -->
        <p class="mt-6 text-earth-brown leading-relaxed">
          {product.detail}
        </p>

        <!-- Certifications -->
        <div class="mt-8">
          <h3 class="text-sm font-semibold text-ink-blue mb-3">认证资质</h3>
          <div class="flex flex-wrap gap-2">
            {product.certifications.map((cert) => (
              <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-bronze-gold/10 text-bronze-gold border border-bronze-gold/20">
                {cert}
              </span>
            ))}
          </div>
        </div>

        <!-- Origin -->
        <div class="mt-6">
          <h3 class="text-sm font-semibold text-ink-blue mb-2">产地信息</h3>
          <p class="text-earth-brown text-sm">
            <span class="inline-block mr-1">&#x1F4CD;</span>
            {product.origin}
          </p>
        </div>

        <!-- Purchase Channels -->
        <div class="mt-8">
          <h3 class="text-sm font-semibold text-ink-blue mb-3">购买渠道</h3>
          <div class="flex gap-4">
            <div class="flex-1 rounded-lg border-2 border-dashed border-linen p-4 text-center">
              <span class="block text-2xl mb-1">&#x1F4F1;</span>
              <span class="text-sm font-medium text-ink-blue">微信</span>
              <p class="text-xs text-earth-brown mt-1">扫码添加客服购买</p>
            </div>
            <div class="flex-1 rounded-lg border-2 border-dashed border-linen p-4 text-center">
              <span class="block text-2xl mb-1">&#x1F6D2;</span>
              <span class="text-sm font-medium text-ink-blue">抖音</span>
              <p class="text-xs text-earth-brown mt-1">搜索店铺"藏宝宝网企业店"</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  {relatedProducts.length > 0 && (
    <section class="bg-cream/50 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-ink-blue mb-8 text-center">相关产品</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedProducts.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
