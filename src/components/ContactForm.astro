---
/**
 * ContactForm component
 * A contact form with fields for name, phone, email, and message.
 */
---

<form
  action="https://formspree.io/f/xxxxxxxx"
  method="POST"
  class="flex flex-col gap-4"
>
  <div class="flex flex-col gap-1.5">
    <label for="name" class="text-sm text-earth-brown">姓名</label>
    <input
      type="text"
      id="name"
      name="name"
      required
      placeholder="请输入姓名"
      class="w-full px-4 py-3 border border-linen rounded bg-white text-ink-blue focus:outline-none focus:border-tibetan-red transition-colors"
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="phone" class="text-sm text-earth-brown">联系电话</label>
    <input
      type="tel"
      id="phone"
      name="phone"
      placeholder="请输入电话号码"
      class="w-full px-4 py-3 border border-linen rounded bg-white text-ink-blue focus:outline-none focus:border-tibetan-red transition-colors"
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="email" class="text-sm text-earth-brown">电子邮箱</label>
    <input
      type="email"
      id="email"
      name="email"
      placeholder="请输入邮箱地址"
      class="w-full px-4 py-3 border border-linen rounded bg-white text-ink-blue focus:outline-none focus:border-tibetan-red transition-colors"
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="message" class="text-sm text-earth-brown">留言内容</label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      placeholder="请输入留言内容"
      class="w-full px-4 py-3 border border-linen rounded bg-white text-ink-blue focus:outline-none focus:border-tibetan-red transition-colors"
    ></textarea>
  </div>

  <button
    type="submit"
    class="self-start bg-tibetan-red text-white px-6 py-3 rounded font-semibold"
  >
    提交留言
  </button>
</form>
