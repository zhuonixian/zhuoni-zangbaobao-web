---
interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  gradient?: string;
}

const {
  title,
  subtitle,
  label,
  gradient = 'from-ink-blue to-ink-blue/80',
} = Astro.props;
---

<section class={`relative bg-gradient-to-r ${gradient} pt-32 pb-20 text-center`}>
  <!-- Top decorative line -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-tibetan-red via-bronze-gold to-tibetan-red"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {label && (
      <span class="inline-block text-bronze-gold text-sm tracking-[0.3em] mb-4">
        {label}
      </span>
    )}
    <h1 class="text-4xl md:text-5xl font-light text-white">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-4 text-white/60 text-lg">
        {subtitle}
      </p>
    )}
  </div>
</section>
