---
const quickLinks = [
  { href: '/', text: '首页' },
  { href: '/about', text: '关于我们' },
  { href: '/products', text: '产品展示' },
  { href: '/culture', text: '文化故事' },
  { href: '/news', text: '新闻资讯' },
  { href: '/contact', text: '联系我们' },
];

const productCategories = [
  '食用菌类',
  '中藏药材',
  '高原畜产',
  '山珍野菜',
  '粮油加工',
  '蜂产品',
  '特色食品',
  '手工艺品',
];
---

<footer class="bg-ink-blue text-white">
  <!-- Decorative gradient line -->
  <div class="h-1 bg-gradient-to-r from-tibetan-red via-bronze-gold to-tibetan-red"></div>

  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand Info -->
      <div class="lg:col-span-1">
        <img src="/images/logo.svg" alt="藏宝宝" class="h-40 w-auto mb-4" />

        <p class="text-white/70 text-sm leading-relaxed mb-4">
          卓尼县藏宝宝网络有限责任公司，致力于推广和销售来自青藏高原的绿色生态土特产，让更多人品尝到大自然的馈赠。
        </p>
        <p class="text-bronze-gold text-sm font-medium tracking-wider">
          藏王故里 · 秘境卓尼
        </p>
      </div>

      <!-- Quick Navigation -->
      <div>
        <h4 class="text-white font-semibold text-base mb-4">快速导航</h4>
        <ul class="space-y-2.5">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-white/60 hover:text-bronze-gold text-sm transition-colors duration-200"
              >
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Product Categories -->
      <div>
        <h4 class="text-white font-semibold text-base mb-4">产品分类</h4>
        <ul class="space-y-2.5">
          {productCategories.map((cat) => (
            <li>
              <a
                href="/products"
                class="text-white/60 hover:text-bronze-gold text-sm transition-colors duration-200"
              >
                {cat}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-white font-semibold text-base mb-4">联系我们</h4>
        <div class="space-y-3">
          <div class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-bronze-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="text-white/60 text-sm">
              甘肃省甘南藏族自治州卓尼县
            </p>
          </div>
          <div class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-bronze-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:contact@zangbaobao.com" class="text-white/60 hover:text-bronze-gold text-sm transition-colors duration-200">
              contact@zangbaobao.com
            </a>
          </div>
          <div class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-bronze-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:15109412225" class="text-white/60 hover:text-bronze-gold text-sm transition-colors duration-200">
              15109412225
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Copyright bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col sm:flex-row items-center justify-between space-y-2 sm:space-y-0">
        <p class="text-white/40 text-xs sm:text-sm">
          &copy; {new Date().getFullYear()} 卓尼县藏宝宝网络有限责任公司 版权所有
        </p>
        <p class="text-white/40 text-xs sm:text-sm">
          藏王故里 · 秘境卓尼 · 高原生态
        </p>
      </div>
    </div>
  </div>
</footer>
