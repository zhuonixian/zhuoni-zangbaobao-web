---

---

<section class="relative h-screen min-h-[600px] flex items-center justify-center bg-ink-blue">
  <!-- Background gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-ink-blue via-ink-blue/90 to-tibetan-red/30"></div>
  <div class="absolute inset-0 bg-black/30"></div>

  <!-- Content -->
  <div class="relative z-10 text-center max-w-3xl px-4">
    <p class="text-bronze-gold tracking-[0.3em] text-sm mb-6">
      藏王故里 · 秘境卓尼
    </p>
    <h1 class="text-white text-4xl md:text-6xl font-light mb-6">
      来自雪域高原的馈赠
    </h1>
    <p class="text-white/70 mb-10 text-lg">
      传承千年藏族文化，甄选高原纯净珍品
    </p>
    <a
      href="/products"
      class="inline-block bg-bronze-gold text-ink-blue px-8 py-3 rounded-md font-medium text-sm tracking-wide transition-all duration-200 hover:brightness-110 hover:scale-105"
    >
      探索产品
    </a>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/40 text-sm animate-bounce">
    ↓ 向下滚动
  </div>
</section>
